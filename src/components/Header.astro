---
// src/components/Header.astro
// Custom single-bar navbar — categories left, brand right
// Replaces AstroPaper's default Header completely

const CATEGORIES = [
  "All",
  "Admissions",
  "Exams",
  "Career",
  "Scholarships",
  "Education News",
  "Study Abroad",
  "College Reviews",
  "Courses",
  "Sarkari Result",
  "Programming",
];
---

<header id="main-header" style="background:#352323;position:sticky;top:0;z-index:50;box-shadow:0 2px 8px rgba(0,0,0,0.25)">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:0 20px;gap:12px">

    <!-- LEFT: Category Pills -->
    <nav
      aria-label="Post categories"
      style="display:flex;align-items:center;gap:5px;overflow-x:auto;padding:10px 0;scrollbar-width:none;flex:1;min-width:0"
    >
      {
        CATEGORIES.map((cat, i) => (
          <button
            class="cat-btn"
            data-cat={cat}
            aria-label={`Filter by ${cat}`}
            style={
              i === 0
                ? "padding:5px 16px;border-radius:20px;font-size:12px;cursor:pointer;border:none;white-space:nowrap;font-weight:600;background:#C47623;color:#fff;flex-shrink:0;transition:all 0.2s"
                : "padding:5px 16px;border-radius:20px;font-size:12px;cursor:pointer;border:none;white-space:nowrap;font-weight:500;background:transparent;color:rgba(255,255,255,0.7);flex-shrink:0;transition:all 0.2s"
            }
          >
            {cat}
          </button>
        ))
      }
    </nav>

    <!-- RIGHT: Brand Name -->
    <a
      href="/"
      style="text-decoration:none;white-space:nowrap;flex-shrink:0;padding:10px 0"
      aria-label="Academic Option - Home"
    >
      <span style="color:#fff;font-size:16px;font-weight:700;letter-spacing:0.01em">
        Academic <span style="color:#C47623">Option</span>
      </span>
    </a>

  </div>
</header>

<style>
  /* Hide scrollbar on category row */
  nav::-webkit-scrollbar {
    display: none;
  }
  .cat-btn:hover {
    background: rgba(196, 118, 35, 0.3) !important;
    color: #fff !important;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const catBtns = document.querySelectorAll<HTMLElement>(".cat-btn");

    // On index page — filter posts
    const postCards = document.querySelectorAll<HTMLElement>(".post-card");
    const noPostsMsg = document.getElementById("no-posts");

    catBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const selectedCat = btn.dataset.cat ?? "All";

        // Update active pill style
        catBtns.forEach((b) => {
          b.style.background = "transparent";
          b.style.color = "rgba(255,255,255,0.7)";
          b.style.fontWeight = "500";
        });
        btn.style.background = "#C47623";
        btn.style.color = "#fff";
        btn.style.fontWeight = "600";

        // Filter cards (only runs if post cards exist on page)
        if (postCards.length > 0) {
          let visibleCount = 0;
          postCards.forEach((card) => {
            const tags: string[] = JSON.parse(card.dataset.tags ?? "[]");
            const show =
              selectedCat === "All" ||
              tags.some(
                (t) => t.toLowerCase() === selectedCat.toLowerCase()
              );
            card.style.display = show ? "block" : "none";
            if (show) visibleCount++;
          });
          if (noPostsMsg) {
            noPostsMsg.style.display = visibleCount === 0 ? "block" : "none";
          }
        }
      });
    });
  });
</script>